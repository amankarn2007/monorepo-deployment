{
  "name": "Excalidraw",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",

    "db:generate": "cd packages/db && bunx prisma generate && cd ../..",

    "build:backend": "cd apps/backend && bun run build",
    "start:backend": "cd apps/backend && node dist/server.js",
    
    "build:web": "cd apps/web && bun run build",
    "start:web": "cd apps/web && bun run start",

    "start:websocket": "cd apps/websocket && bun run index.ts"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.7",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
